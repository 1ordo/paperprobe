# Database
POSTGRES_USER=cosmin
POSTGRES_PASSWORD=cosmin_secret
POSTGRES_DB=cosmin_checker
DATABASE_URL=postgresql+asyncpg://cosmin:cosmin_secret@postgres:5432/cosmin_checker
DATABASE_URL_SYNC=postgresql://cosmin:cosmin_secret@postgres:5432/cosmin_checker

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# AI API
AI_API_BASE_URL=http://your-ai-server:1234/v1
AI_API_KEY=
AI_MODEL_PRIMARY=openai/gpt-oss-120b
AI_MODEL_FAST=qwen3.5-35b-a3b
AI_MODEL_EMBEDDING=text-embedding-nomic-embed-text-v1.5

# Auth
AUTH_EMAIL=admin@cosmin.local
AUTH_PASSWORD=changeme
AUTH_SECRET=change-this-secret-key-in-production

# Upload
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=100
